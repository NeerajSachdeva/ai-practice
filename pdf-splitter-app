<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>PDF Splitter</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<!-- Libraries -->
<script src="https://unpkg.com/pdf-lib/dist/pdf-lib.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

<style>
*{box-sizing:border-box}

body{
font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif;
margin:0;
min-height:100vh;
display:flex;
align-items:center;
justify-content:center;
background:linear-gradient(135deg,#0f2027,#203a43,#2c5364);
padding:20px;
}

.card{
background:#fff;
width:100%;
max-width:520px;
border-radius:16px;
padding:28px;
box-shadow:0 20px 45px rgba(0,0,0,.25);
transition:all .3s ease;
}

.card:hover{
transform:translateY(-3px);
box-shadow:0 25px 50px rgba(0,0,0,.3);
}

h2{
text-align:center;
margin-top:0;
margin-bottom:20px;
color:#2c5364;
}

.drop-area{
border:2px dashed #ccc;
border-radius:12px;
padding:30px;
text-align:center;
cursor:pointer;
transition:.25s;
}

.drop-area.dragover{
border-color:#2c5364;
background:#f4f8fa;
}

input[type=file]{display:none}

label{
font-size:14px;
font-weight:600;
margin-top:15px;
display:block;
}

input[type=text]{
width:100%;
padding:10px;
margin-top:6px;
border-radius:8px;
border:1px solid #ddd;
}

.options{
margin-top:12px;
display:flex;
align-items:center;
gap:10px;
font-size:14px;
}

button{
width:100%;
margin-top:20px;
padding:12px;
border:none;
border-radius:8px;
background:#2c5364;
color:white;
font-size:16px;
cursor:pointer;
transition:.25s;
}

button:hover{
background:#1f3b4a;
transform:translateY(-1px);
}

.result{
margin-top:20px;
text-align:center;
opacity:0;
transform:translateY(10px);
transition:.35s;
}

.result.show{
opacity:1;
transform:translateY(0);
}

.download-btn{
background:#27ae60;
margin-top:10px;
}

.download-btn:hover{
background:#1e874b;
}

.note{
margin-top:10px;
font-size:12px;
color:#666;
text-align:center;
}

@media(max-width:480px){
.card{padding:22px}
}
</style>
</head>

<body>

<div class="card">

<h2>PDF Page Splitter</h2>

<div class="drop-area" id="dropArea">
<p id="fileLabel">Drop PDF here or click to upload</p>
<input type="file" id="fileInput" accept="application/pdf">
</div>

<label>Split Page Range (example: 3-8)</label>
<input id="rangeInput" type="text" placeholder="Optional">

<label>OR Specific Pages (example: 1,5,9)</label>
<input id="pagesInput" type="text" placeholder="Optional">

<div class="options">
<input type="checkbox" id="splitAll">
<span>Split ALL pages (download ZIP)</span>
</div>

<button id="splitBtn">Split PDF</button>

<div class="result" id="resultBox">
<p id="resultText"></p>
<a id="downloadLink">
<button class="download-btn">Download</button>
</a>
</div>

<p class="note">Files are processed locally in your browser. Nothing is uploaded.</p>

</div>

<script>

let selectedFile=null;
const dropArea=document.getElementById("dropArea");
const fileInput=document.getElementById("fileInput");

// click upload
dropArea.addEventListener("click",()=>fileInput.click());

fileInput.addEventListener("change",e=>{
selectedFile=e.target.files[0];
if(selectedFile){
document.getElementById("fileLabel").innerText=selectedFile.name;
}
});

// drag drop
dropArea.addEventListener("dragover",e=>{
e.preventDefault();
dropArea.classList.add("dragover");
});

dropArea.addEventListener("dragleave",()=>{
dropArea.classList.remove("dragover");
});

dropArea.addEventListener("drop",e=>{
e.preventDefault();
dropArea.classList.remove("dragover");

const file=e.dataTransfer.files[0];
if(file && file.type==="application/pdf"){
selectedFile=file;
document.getElementById("fileLabel").innerText=file.name;
}
});

document.getElementById("splitBtn").addEventListener("click",splitPDF);

async function splitPDF(){

if(!selectedFile){
alert("Please upload a PDF file");
return;
}

const { PDFDocument } = PDFLib;
const zip=new JSZip();

const bytes=await selectedFile.arrayBuffer();
const pdfDoc=await PDFDocument.load(bytes);

const totalPages=pdfDoc.getPageCount();

const range=document.getElementById("rangeInput").value.trim();
const specific=document.getElementById("pagesInput").value.trim();
const splitAll=document.getElementById("splitAll").checked;

const link=document.getElementById("downloadLink");

if(splitAll){

for(let i=0;i<totalPages;i++){

const newPdf=await PDFDocument.create();
const [page]=await newPdf.copyPages(pdfDoc,[i]);
newPdf.addPage(page);

const pdfBytes=await newPdf.save();
zip.file(`page-${i+1}.pdf`,pdfBytes);

}

const zipBlob=await zip.generateAsync({type:"blob"});
const url=URL.createObjectURL(zipBlob);

link.href=url;
link.download="split-pages.zip";

document.getElementById("resultText").innerText="All pages split successfully.";

}else{

let pages=[];

if(range){

const parts=range.split("-");
const start=parseInt(parts[0]);
const end=parseInt(parts[1]);

for(let i=start;i<=end;i++){
pages.push(i-1);
}

}else if(specific){

pages=specific.split(",").map(p=>parseInt(p.trim())-1);

}else{

alert("Enter range, specific pages, or select split all.");
return;

}

const newPdf=await PDFDocument.create();

for(let p of pages){

if(p>=0 && p<totalPages){

const [page]=await newPdf.copyPages(pdfDoc,[p]);
newPdf.addPage(page);

}

}

const pdfBytes=await newPdf.save();
const blob=new Blob([pdfBytes],{type:"application/pdf"});
const url=URL.createObjectURL(blob);

link.href=url;
link.download="split.pdf";

document.getElementById("resultText").innerText="Your split PDF is ready.";

}

document.getElementById("resultBox").classList.add("show");

}

</script>

</body>
</html>
